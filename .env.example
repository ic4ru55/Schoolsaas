# Local database
DATABASE_URL="postgresql://schoolsaas:schoolsaas@localhost:5434/schoolsaas_bf?schema=public"
POSTGRES_DB=schoolsaas_bf
POSTGRES_USER=schoolsaas
POSTGRES_PASSWORD=schoolsaas

# API
APP_PORT=4000
JWT_SECRET="change-me-before-production"

# Web
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# Local backups
BACKUP_LOCAL_DIR="./data/backups"
BACKUP_ENCRYPTION_KEY="replace-with-a-32-byte-secret"

# Cloud backup target, S3 compatible
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

